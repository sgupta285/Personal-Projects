APP_ENV=local
STORAGE_MODE=local
OBJECT_BUCKET=benchmarks
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
CACHE_MODE=memory
CACHE_CAPACITY_MB=64
STORE_ROOT=data/store
BENCHMARK_OUTPUT_DIR=data/benchmarks
REPORT_OUTPUT_DIR=data/reports
HOT_OBJECT_COUNT=8
RUN_SEED=42
