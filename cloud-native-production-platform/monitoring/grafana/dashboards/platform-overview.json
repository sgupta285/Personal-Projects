{
  "title": "Platform Overview",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Gateway Requests",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_requests_total{service='gateway'}[5m]))" }]
    },
    {
      "type": "stat",
      "title": "Order Requests",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_requests_total{service='orders'}[5m]))" }]
    },
    {
      "type": "timeseries",
      "title": "Gateway Latency",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service='gateway'}[5m])) by (le))" }]
    }
  ]
}
