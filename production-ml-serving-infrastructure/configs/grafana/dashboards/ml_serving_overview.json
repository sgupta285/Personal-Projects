{
  "title": "ML Serving Overview",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ml_serving_requests_total[1m]))",
          "legendFormat": "requests/sec"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 Latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ml_serving_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(ml_serving_cache_events_total{result=\"hit\"}[5m])) / sum(rate(ml_serving_cache_events_total[5m]))",
          "legendFormat": "ratio"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Average Batch Size",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(ml_serving_batch_size_sum[5m]) / rate(ml_serving_batch_size_count[5m])",
          "legendFormat": "avg"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s"
}
