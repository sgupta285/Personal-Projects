APP_NAME=production-ml-serving-infrastructure
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite+pysqlite:///./ml_serving.db
REDIS_URL=redis://localhost:6379/0
MLFLOW_TRACKING_URI=file:./mlruns
MODEL_PATH=artifacts/models/current_model.pt
MODEL_REGISTRY_PATH=artifacts/model_registry/current.json
REQUEST_BATCH_WINDOW_MS=100
REQUEST_MAX_BATCH_SIZE=32
IN_MEMORY_CACHE_TTL_SECONDS=120
IN_MEMORY_CACHE_MAXSIZE=512
REDIS_CACHE_TTL_SECONDS=300
FEATURE_LOOKBACK_DAYS=30
ENABLE_REDIS=false
ENABLE_DYNAMIC_BATCHING=true
ENABLE_FALLBACK_MODEL=true
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
